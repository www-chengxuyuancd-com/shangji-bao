# Flask
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=请修改为随机字符串

# PostgreSQL (容器内部通信，无需修改)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/shangjibao

# MongoDB
MONGO_URI=mongodb://mongodb:mongodb@mongodb:27017/shangjibao?authSource=admin

# Admin 登录账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=请修改密码

# 大模型配置（也可在后台管理页面中配置）
# DEEPSEEK_API_KEY=sk-xxx
# DEEPSEEK_BASE_URL=https://api.deepseek.com
