# Flask
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-in-production

# PostgreSQL
DATABASE_URL=postgresql://shangji:shangji123@localhost:5432/shangjibao

# MongoDB
MONGO_URI=mongodb://shangji:shangji123@localhost:27017/shangjibao?authSource=admin

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ===== 代理池 =====
# 静态代理列表（逗号分隔），示例: http://1.2.3.4:8080,socks5://5.6.7.8:1080
PROXY_LIST=
# 代理 API 地址（返回代理列表的 HTTP 接口）
PROXY_API_URL=
# 代理 API 拉取间隔（秒）
PROXY_API_INTERVAL=60

# ===== 验证码 =====
# 第三方打码平台 API 地址
CAPTCHA_API_URL=
# 第三方打码平台 API Key
CAPTCHA_API_KEY=
# 打码超时（秒）
CAPTCHA_API_TIMEOUT=30
